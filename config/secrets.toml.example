# Tagentacle Secrets Configuration Template
# Copy this file to secrets.toml and fill in your values:
#   cp secrets.toml.example secrets.toml
#
# config/secrets.toml is gitignored. NEVER commit it.
#
# Loaded by `tagentacle launch` and injected into every node's
# `node.secrets` map (also exported as environment variables for
# subprocesses).

# --- LLM Endpoint (REQUIRED for example-inference) ---
# example-inference refuses to start if either of these is missing.
# Use whichever provider you have access to; OpenRouter is convenient
# for evaluating multiple models behind one key.
OPENAI_API_KEY = "sk-..."
OPENAI_BASE_URL = "https://openrouter.ai/api/v1"

# --- Optional providers (uncomment as needed) ---
# ANTHROPIC_API_KEY = "sk-ant-..."
# DEEPSEEK_API_KEY  = "sk-..."

# --- External service tokens ---
# GITHUB_TOKEN     = "ghp_..."
# SLACK_BOT_TOKEN  = "xoxb-..."

# --- Database ---
# DATABASE_URL = "postgresql://user:pass@localhost/db"
